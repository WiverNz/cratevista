# Keep every detected text file stable across Windows, macOS, and Linux.
* text=auto eol=lf

# Keep canonical JSON artifacts and fixtures at LF so byte-equality holds
# across platforms (roundtrip and schema-drift tests compare exact bytes).
crates/cratevista-schema/schema/*.json text eol=lf
crates/cratevista-schema/fixtures/*.json text eol=lf
# Markdown fixture bytes are embedded verbatim and compared in cross-platform tests.
crates/cratevista-config/tests/fixtures/**/*.md text eol=lf
