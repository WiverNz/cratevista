{
  "name": "cratevista-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CrateVista interactive architecture explorer (frontend).",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint .",
    "typecheck": "node ./node_modules/typescript-7/bin/tsc --noEmit",
    "typecheck:compat": "tsc6 --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "generate:types": "node scripts/gen-types.mjs",
    "check:types": "node scripts/check-types.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:embed-rebuild": "node scripts/check-embed-rebuild.mjs",
    "license:web": "node scripts/license-report.mjs",
    "license:web:check": "node scripts/license-report.mjs --check",
    "refresh:fixtures": "node scripts/refresh-fixtures.mjs",
    "refresh:e2e-snapshots": "node scripts/refresh-e2e-snapshots.mjs",
    "gen:benchmark-workspaces": "node scripts/gen-benchmark-workspaces.mjs",
    "benchmark": "playwright test --config playwright.bench.config.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.2",
    "elkjs": "^0.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.20.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "npm:@typescript/typescript6@^6.0.0",
    "typescript-7": "npm:typescript@7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
